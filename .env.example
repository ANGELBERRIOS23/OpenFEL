# OpenFEL Configuration
# Copy this file to .env and fill in your values

# Master encryption key (auto-generated on first boot if empty)
# IMPORTANT: back this up — losing it means losing access to encrypted credentials
OPENFEL_MASTER_KEY=

# Database (default: SQLite in ./data/)
# For PostgreSQL: postgresql+asyncpg://user:pass@host/openfel
DATABASE_URL=sqlite+aiosqlite:///./data/openfel.db

# CORS origins (comma-separated)
CORS_ORIGINS=["http://localhost:5173","http://localhost:8000"]

# Logging level
LOG_LEVEL=info
